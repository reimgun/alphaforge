# ── Crypto Bot Konfiguration ──────────────────────────────────────────────────
# Secrets werden von scripts/gen-env.sh aus pass befüllt.

# ── Handelsmodus ──────────────────────────────────────────────────────────────
TRADING_MODE=paper
INITIAL_CAPITAL=5000

# ── Binance API (Secrets via pass) ───────────────────────────────────────────
BINANCE_API_KEY=__BINANCE_API_KEY__
BINANCE_API_SECRET=__BINANCE_API_SECRET__

# ── KI ────────────────────────────────────────────────────────────────────────
AI_MODE=ml
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__

# ── Groq / LLM (Secret via pass) ─────────────────────────────────────────────
GROQ_API_KEY=__GROQ_API_KEY__

# ── Telegram (Secrets via pass) ───────────────────────────────────────────────
TELEGRAM_TOKEN=__TELEGRAM_TOKEN__
TELEGRAM_CHAT_ID=__TELEGRAM_CHAT_ID__

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TIMEFRAME=1h
TREND_TIMEFRAME=4h
ML_LOOKAHEAD=4

# ── Broker-Auswahl ────────────────────────────────────────────────────────────
# Wähle einen Broker: oanda | capital | ig | ibkr
FOREX_BROKER=oanda

# ── OANDA API ─────────────────────────────────────────────────────────────────
# Practice Account: https://www.oanda.com/register/#/sign-up/demo
# Live Account:     https://www.oanda.com/register/#/sign-up
OANDA_API_KEY=your-oanda-api-key-here
OANDA_ACCOUNT_ID=your-account-id-here        # z.B. 101-001-12345678-001
OANDA_ENV=practice                            # practice | live

# ── Capital.com API ───────────────────────────────────────────────────────────
# Demo-Account kostenlos: https://capital.com → Demo-Konto eröffnen
# API-Key: Mein Profil → API-Schlüssel generieren
# FOREX_BROKER=capital
# CAPITAL_API_KEY=dein-api-key
# CAPITAL_EMAIL=deine@email.com
# CAPITAL_PASSWORD=dein-passwort
# CAPITAL_ENV=demo                            # demo | live

# ── IG Group API ──────────────────────────────────────────────────────────────
# Demo-Account: ig.com → "Demo-Konto eröffnen"
# API-Key: ig.com → Mein Konto → API-Schlüssel
# FOREX_BROKER=ig
# IG_API_KEY=dein-api-key
# IG_USERNAME=dein-benutzername
# IG_PASSWORD=dein-passwort
# IG_ENV=demo                                 # demo | live
# IG_ACCOUNT_ID=                              # optional — wenn mehrere Accounts

# ── Interactive Brokers (IBKR via ib_insync) ─────────────────────────────────
# IB Gateway herunterladen: ibkr.com/trader-workstation
# API aktivieren: Edit → Global Configuration → API → Settings
# pip install ib_insync
# FOREX_BROKER=ibkr
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497                              # 7497=TWS Paper, 7496=TWS Live, 4002=GW Paper, 4001=GW Live
# IBKR_CLIENT_ID=1
# IBKR_ACCOUNT=                               # leer = erster Account

# ── Trading ───────────────────────────────────────────────────────────────────
FOREX_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY
FOREX_TIMEFRAME=H1
FOREX_INITIAL_CAPITAL=10000
FOREX_TRADING_MODE=paper                      # paper | live

# ── Risiko ────────────────────────────────────────────────────────────────────
FOREX_RISK_PER_TRADE=0.01                     # 1% pro Trade
FOREX_MAX_DRAWDOWN=0.15                       # 15% Circuit Breaker
FOREX_MAX_OPEN_TRADES=3
FOREX_ATR_MULTIPLIER=1.5
FOREX_RR_RATIO=2.0                            # Reward:Risk Verhältnis

# ── Strategie ─────────────────────────────────────────────────────────────────
FOREX_EMA_FAST=20
FOREX_EMA_SLOW=50
FOREX_EMA_TREND=200
FOREX_RSI_PERIOD=14
FOREX_MIN_CONFIDENCE=0.65

# ── Session-Filter ────────────────────────────────────────────────────────────
FOREX_SESSION_FILTER=true
FOREX_SESSION_START_H=7                       # UTC (7 = London Open)
FOREX_SESSION_END_H=20                        # UTC (20 = NY Close)

# ── Wirtschaftskalender ───────────────────────────────────────────────────────
FOREX_NEWS_PAUSE_MIN=30
FOREX_NEWS_CURRENCIES=USD,EUR,GBP,JPY,CHF,CAD,AUD,NZD

# ── Telegram (eigener Bot — nicht der Krypto-Bot!) ───────────────────────────
# Neuen Bot erstellen: @BotFather → /newbot
FOREX_TELEGRAM_TOKEN=your-forex-bot-token
FOREX_TELEGRAM_CHAT_ID=your-chat-id

# ── Dashboard API ─────────────────────────────────────────────────────────────
FOREX_API_PORT=8001

# ── Risk Mode (Feature 2) ─────────────────────────────────────────────────────
# conservative — 0.5% risk, strictest filters, London/NY overlap only
# balanced     — 1.0% risk, multi-timeframe required (default)
# aggressive   — 2.0% risk, minimal filters
FOREX_RISK_MODE=balanced

# ── ML / Auto-Retrain (Feature 6) ────────────────────────────────────────────
# Number of completed trades before the XGBoost model is automatically retrained
FOREX_RETRAIN_AFTER_TRADES=50

# ── Externe Daten (optional) ──────────────────────────────────────────────────
# FRED API (kostenlos): https://fred.stlouisfed.org/docs/api/api_key.html
# Verbessert Treasury-Yield-Daten und Fed Funds Rate (fallback: Yahoo Finance)
FRED_API_KEY=

# Groq API (kostenlos, schnell): https://console.groq.com
# Für LLM-Filter bei unsicheren Signalen (0.50–0.68 confidence)
GROQ_API_KEY=

# Anthropic Claude (kostenpflichtig) — Fallback wenn Groq nicht verfügbar
# ANTHROPIC_API_KEY=

# ── Multi-Strategy (Feature neu) ─────────────────────────────────────────────
# true = Bot wählt automatisch die beste Strategie (EMA/Breakout/MeanReversion)
# false = nur EMA-Crossover (legacy-Verhalten)
FOREX_MULTI_STRATEGY=true

# ── Session Quality Filter ────────────────────────────────────────────────────
# true = Position-Größe wird per Session-Liquidität angepasst
# false = einheitliche Position-Größe
FOREX_SESSION_QUALITY=true

# ── Shared Exposure (Crypto + Forex Portfolio-Koordination) ──────────────────
# Pfad zur JSON-Datei für cross-bot Exposure-Tracking
# Muss in beiden Bot-Containern als Volume gemountet sein
SHARED_EXPOSURE_PATH=/tmp/trading_shared_exposure.json

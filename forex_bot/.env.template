# ── Forex Bot Konfiguration ───────────────────────────────────────────────────
# Secrets (IG_API_KEY etc.) werden von scripts/gen-env.sh aus pass befüllt.
# Diese Datei enthält nur nicht-sensible Konfiguration.

# ── Broker ────────────────────────────────────────────────────────────────────
FOREX_BROKER=ig

# ── IG Group API (Secrets via pass) ──────────────────────────────────────────
IG_API_KEY=__IG_API_KEY__
IG_USERNAME=__IG_USERNAME__
IG_PASSWORD=__IG_PASSWORD__
IG_ENV=demo
IG_ACCOUNT_ID=__IG_ACCOUNT_ID__

# ── Alpaca Markets (Secrets via pass) ────────────────────────────────────────
# Broker auf "alpaca" setzen um Alpaca zu nutzen: FOREX_BROKER=alpaca
# Paper Trading Keys (gratis, sofort verfügbar)
ALPACA_API_KEY_PAPER=__ALPACA_API_KEY_PAPER__
ALPACA_API_SECRET_PAPER=__ALPACA_API_SECRET_PAPER__
# Live Trading Keys
ALPACA_API_KEY_LIVE=__ALPACA_API_KEY_LIVE__
ALPACA_API_SECRET_LIVE=__ALPACA_API_SECRET_LIVE__
ALPACA_ENV=paper

# ── Trading ───────────────────────────────────────────────────────────────────
FOREX_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY
FOREX_TIMEFRAME=H1
FOREX_INITIAL_CAPITAL=10000
FOREX_TRADING_MODE=paper

# ── Risiko ────────────────────────────────────────────────────────────────────
FOREX_RISK_PER_TRADE=0.01
FOREX_MAX_DRAWDOWN=0.15
FOREX_MAX_OPEN_TRADES=3
FOREX_ATR_MULTIPLIER=1.5
FOREX_RR_RATIO=2.0

# ── Strategie ─────────────────────────────────────────────────────────────────
FOREX_EMA_FAST=20
FOREX_EMA_SLOW=50
FOREX_EMA_TREND=200
FOREX_RSI_PERIOD=14
FOREX_MIN_CONFIDENCE=0.58

# ── Session-Filter ────────────────────────────────────────────────────────────
FOREX_SESSION_FILTER=true
FOREX_SESSION_START_H=7
FOREX_SESSION_END_H=20

# ── Wirtschaftskalender ───────────────────────────────────────────────────────
FOREX_NEWS_PAUSE_MIN=30
FOREX_NEWS_CURRENCIES=USD,EUR,GBP,JPY

# ── Telegram (Secrets via pass) ───────────────────────────────────────────────
FOREX_TELEGRAM_TOKEN=__FOREX_TELEGRAM_TOKEN__
FOREX_TELEGRAM_CHAT_ID=__FOREX_TELEGRAM_CHAT_ID__
FOREX_TELEGRAM_POLLING=true

# ── Dashboard API ─────────────────────────────────────────────────────────────
FOREX_API_PORT=8001

# ── Risk Mode ─────────────────────────────────────────────────────────────────
FOREX_RISK_MODE=balanced

# ── ML ────────────────────────────────────────────────────────────────────────
FOREX_RETRAIN_AFTER_TRADES=999999

# ── Features ──────────────────────────────────────────────────────────────────
FOREX_MULTI_STRATEGY=true
FOREX_SESSION_QUALITY=true

# ── Externe Daten (Secrets via pass) ─────────────────────────────────────────
FRED_API_KEY=__FRED_API_KEY__
GROQ_API_KEY=__GROQ_API_KEY__

# ── Shared Exposure ───────────────────────────────────────────────────────────
SHARED_EXPOSURE_PATH=/app/data/shared_exposure.json

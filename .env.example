# ── Handelsmodus ────────────────────────────────────────────────────────────
# paper:   Lokale Simulation, kein Binance-Account nötig (Standard)
# testnet: Binance Testnet — echte API, virtuelles Geld
#          Keys von: https://testnet.binance.vision (Login via GitHub)
# live:    Echtes Geld — nur nach expliziter Bestätigung aktiviert
TRADING_MODE=paper

# ── Startkapital (nur Paper-Modus) ───────────────────────────────────────────
INITIAL_CAPITAL=1000

# ── Binance API Keys ─────────────────────────────────────────────────────────
# Paper-Modus: nicht benötigt
# Testnet:     Keys von testnet.binance.vision (NICHT die Production-Keys!)
# Live:        Keys von binance.com → Profil → API Management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── KI-Modus ─────────────────────────────────────────────────────────────────
# ml:       XGBoost Modell — kein API-Key nötig (empfohlen)
# combined: ML + LLM — benötigt AI_PROVIDER + passenden API-Key
# rules:    Regelbasiert ohne ML
# claude:   Nur LLM (AI_PROVIDER bestimmt welcher)
AI_MODE=ml

# ── LLM Provider (nur für AI_MODE=combined oder claude) ──────────────────────
# claude  — Anthropic Claude (Standard, bewährt)
# openai  — OpenAI GPT-4o-mini / GPT-4o
# gemini  — Google Gemini 1.5 Flash (günstig)
# groq    — Groq LLaMA 3.3 70B (kostenlos, sehr schnell)
# ollama  — Lokales Modell, kein API-Key, vollständig offline
AI_PROVIDER=claude

# Modell überschreiben (leer = Provider-Standard):
# claude:  claude-opus-4-6
# openai:  gpt-4o-mini
# gemini:  gemini-1.5-flash
# groq:    llama-3.3-70b-versatile
# ollama:  llama3
AI_MODEL=

# ── LLM API Keys (je nach AI_PROVIDER nur den passenden befüllen) ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ── Ollama Host (nur für AI_PROVIDER=ollama, Standard: localhost) ─────────────
OLLAMA_HOST=http://localhost:11434

# ── Telegram Alerts (optional) ───────────────────────────────────────────────
# Bot erstellen: @BotFather in Telegram → /newbot
# Chat-ID:       @userinfobot in Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Dashboard Sicherheit (empfohlen im Heimnetz) ──────────────────────────────
# API-Key für schreibende Dashboard-Endpunkte (start/stop/retrain etc.)
# Leer lassen = kein Schutz (nur im abgeschlossenen LAN vertretbar)
# Beliebiges Passwort setzen, z.B.: openssl rand -hex 16
DASHBOARD_API_KEY=

# ── Marktkontext (Round 10) ───────────────────────────────────────────────────
# Fear & Greed Index — kostenlos, kein API-Key nötig (alternative.me)
# Extreme Fear/Greed beeinflusst Positionsgröße und blockiert ggf. BUY
FEATURE_FEAR_GREED=true

# ── Global Exposure Controller (Round 11) ────────────────────────────────────
# Portfolio-Level Kapital-Steuerung — skaliert alle Positionen dynamisch
# Erkennt Krisen, aktiviert Risk-Off, Recovery nach Erholung
# Telegram: /exposure_status /risk_off_mode /resume_trading /set_max_exposure
FEATURE_GLOBAL_EXPOSURE=true

# News Sentiment — wertet aktuelle Krypto-Schlagzeilen aus (CoinDesk, CoinTelegraph)
# Mit LLM (AI_PROVIDER): tiefe Analyse | Ohne LLM: Keyword-basierter Fallback
FEATURE_NEWS_SENTIMENT=true

# ── Log-Level ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
